<mxfile host="app.diagrams.net">
  <diagram name="Página-1" id="tEqcBNItckmYbBFxnEw7">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n\n%% ─────────────────────────────────────────\n%% MÓDULO 1 — CATÁLOGO (Composite + Visitor)\n%% ─────────────────────────────────────────\nclass ElementoReportable {\n    &lt;&lt;interface&gt;&gt;\n    +accept(iv: ItemVisitor) void\n}\nclass ItemCatalogo {\n    &lt;&lt;abstract&gt;&gt;\n    -nombre: String\n    -descripcion: String\n    +getPrecioBase() float\n    +validar() boolean\n    +getPeso() float\n    +getNombre() String\n    +getDescripcion() String\n}\nclass Producto {\n    +sku: String\n    +marca: String\n    +categoria: String\n    -precio: Float\n    -peso Float\n    +descuentoPromo: Float\n    -atributosDinamicos: Map~String,Object~\n    +getPrecioBase() float\n    +getPrecioFinal() float\n    +getPeso() float\n    +getAtributosDinamicos() Map~String,Object~\n    +accept(iv: ItemVisitor) void\n    +setCategoria() void\n    +setDescuento() void\n    +addAtributoDinamico(String,Object) void\n    +deleteAtributoDinamico(String) void\n    +validar() boolean\n}\nclass Paquete {\n    +descuento: Float\n    +setDescuento(d: Float) void\n    +getPrecioBase() float\n    +getPeso() float\n    +accept(iv: ItemVisitor) void\n    +agregar(i: ItemCatalogo) void\n    +remover(i: ItemCatalogo) void\n    +validar() boolean\n}\nclass Catalogo {\n    +agregar(i: ItemCatalogo) void\n    +buscar(c: CriterioBusqueda) List~ItemCatalogo~\n}\nclass Entrada {\n    -unidadesVendidas: int\n    -precioPromedio: float\n    +setUnidadesVendidas(u: int) void\n    +agregarDatos(e: Entrada) Entrada\n    +getUnidadesVendidas() int\n    +getItemCatalogo() ItemCatalogo\n    +getPrecioPromedio() float\n} \nclass GeneradorReportes {\n    +generarReporte(ps: List~Pedido~, f1: LocalDate, f2: LocalDate, r: ReporteVisitor, f: FormatoExportador) String\n    -pedidosToLineaPedidos(ps: List~Pedido~, f1: LocalDate, f2: LocalDate) List~LineaPedido~\n}\nclass ItemVisitor {\n    &lt;&lt;interface&gt;&gt;\n    +visit(pr: Producto) void\n    +visit(pq: Paquete) void\n}\nclass ReporteVisitor {\n    &lt;&lt;abstract&gt;&gt;\n    #cantidadActual: int\n    #precioCobradoActual: float\n    +setVentaActual(c: int, p: float) void\n    +getFinishedList() List~Entrada~\n    +titulo() String\n}\nclass VisitorItemsMasVendidos {\n    +visit(pr: Producto) void\n    +visit(pq: Paquete) void\n    +getFinishedList() List~Entrada~\n    +titulo() String\n}\nclass FormatoExportador {\n    &lt;&lt;interface&gt;&gt;\n    +exportar(t: String, f1: LocalDate, f2: LocalDate, es List~Entrada~) String\n}\nclass ExportadorCSV {\n    +exportar(t: String, f1: LocalDate, f2: LocalDate, es List~Entrada~) String\n}\nclass ExportadorHTML {\n    +exportar(t: String, f1: LocalDate, f2: LocalDate, es List~Entrada~) String\n}\nclass ExportadorTXT {\n    +exportar(t: String, f1: LocalDate, f2: LocalDate, es List~Entrada~) String\n}\n\n%% Herencia e implementación\nElementoReportable &lt;|.. ItemCatalogo\nItemCatalogo &lt;|-- Producto\nItemCatalogo &lt;|-- Paquete\nItemVisitor &lt;|.. ReporteVisitor\nReporteVisitor &lt;|-- VisitorItemsMasVendidos\nFormatoExportador &lt;|.. ExportadorCSV\nFormatoExportador &lt;|.. ExportadorHTML\nFormatoExportador &lt;|.. ExportadorTXT\n\n%% Composite\nPaquete \&quot;1\&quot; o-- \&quot;0..*\&quot; ItemCatalogo : contiene\nCatalogo \&quot;1\&quot; o-- \&quot;0..*\&quot; ItemCatalogo : contiene\n\n%% Entrada → ItemCatalogo (asociación, antes era atributo)\nEntrada \&quot;0..*\&quot; --&gt; \&quot;1\&quot; ItemCatalogo : referencia\n\n%% VisitorItemsMasVendidos → Entrada (antes era Map oculto)\nVisitorItemsMasVendidos \&quot;1\&quot; o-- \&quot;0..*\&quot; Entrada : acumula\n\n%% GeneradorReportes (faltaban todas sus relaciones)\nGeneradorReportes ..&gt; ReporteVisitor   : usa\nGeneradorReportes ..&gt; FormatoExportador : usa\nGeneradorReportes ..&gt; Entrada           : produce\n\n\n%% ─────────────────────────────────────────\n%% MÓDULO 2 — PEDIDO (State + Observer)\n%% ─────────────────────────────────────────\n\nclass Cliente {\n    +nombre: String\n    +email: String\n    +direccion: Direccion\n}\n\nclass LineaPedido {\n    +item: ItemCatalogo\n    +cantidad: int\n    +precioUnitario: float\n    +getSubtotal() float\n}\n\nclass Pedido {\n    -id: String\n    -cliente: Cliente\n    -items: List~LineaPedido~\n    -estado: EstadoPedido\n    -metodoEnvio: MetodoEnvio\n    -procesadorPago: ProcesadorPago\n    -observadores: List~Observador~\n    -notasCredito: List~NotaCredito~\n    -fechaCreacion: LocalDate\n    -fechaConfirmacion: LocalDate\n    -fechaEntrega: LocalDate\n    -fechaCancelacion: LocalDate\n    +agregarItem(i: ItemCatalogo) void\n    +quitarItem(i: ItemCatalogo) void\n    +confirmar() void\n    +preparar() void\n    +enviar() void\n    +entregar() void\n    +cancelar() void\n    #cambiarEstado(e: EstadoPedido) void\n    +decrementarStock() void\n    +reponerStock() void\n    +generarNotaCredito(monto: float) void\n    +registrarFechaConfirmacion() void\n    +registrarFechaEntrega() void\n    +registrarFechaCancelacion() void\n    +suscribir(o: Observador) void\n    +desuscribir(o: Observador) void\n    +notificar() void\n    +getSubtotalProductos() float\n    +getCostoEnvio() float\n    +getTotal() float\n    +getPesoTotal() float\n    +getFechaEntrega() LocalDate\n    +getItems() List~LineaPedido~\n}\n\nclass NotaCredito {\n    +monto: float\n    +fecha: LocalDate\n    +motivo: String\n}\n\nclass EstadoPedido {\n    &lt;&lt;interface&gt;&gt;\n    +agregarItem(p: Pedido) void\n    +quitarItem(p: Pedido) void\n    +confirmar(p: Pedido) void\n    +cancelar(p: Pedido) void\n    +preparar(p: Pedido) void\n    +enviar(p: Pedido) void\n    +entregar(p: Pedido) void\n    +notificarObservador (o: Observador, p: Pedido, e: EstadoPedido) void\n}\n\nclass EstadoBorrador {\n    +agregarItem(p: Pedido) void\n    +quitarItem(p: Pedido) void\n    +confirmar(p: Pedido) void\n    +cancelar(p: Pedido) void\n}\n\nclass EstadoConfirmado {\n    +confirmar(p: Pedido) void\n    +cancelar(p: Pedido) void\n    +preparar(p: Pedido) void\n    +notificarObservador (o: Observador, p: Pedido, e: EstadoPedido) void\n}\n\nclass EstadoEnPreparacion {\n    +enviar(p: Pedido) void\n}\n\nclass EstadoEnviado {\n    +entregar(p: Pedido) void\n    +cancelar(p: Pedido) void\n    +notificarObservador (o: Observador, p: Pedido, e: EstadoPedido) void\n}\n\nclass EstadoEntregado {\n    +notificarObservador (o: Observador, p: Pedido, e: EstadoPedido) void\n}\n\nclass EstadoCancelado {\n    +notificarObservador (o: Observador, p: Pedido, e: EstadoPedido) void\n}\n\nEstadoPedido &lt;|.. EstadoBorrador\nEstadoPedido &lt;|.. EstadoConfirmado\nEstadoPedido &lt;|.. EstadoEnPreparacion\nEstadoPedido &lt;|.. EstadoEnviado\nEstadoPedido &lt;|.. EstadoEntregado\nEstadoPedido &lt;|.. EstadoCancelado\n\nPedido --&gt; EstadoPedido : estado\nPedido --&gt; Cliente\nPedido --&gt; MetodoEnvio\nPedido --&gt; ProcesadorPago\nPedido \&quot;1\&quot; *-- \&quot;0..*\&quot; LineaPedido\nPedido \&quot;1\&quot; *-- \&quot;0..*\&quot; NotaCredito\nLineaPedido --&gt; ItemCatalogo\n\n\n%% ─────────────────────────────────────────\n%% MÓDULO 3 — ENVÍOS (Strategy)\n%% ─────────────────────────────────────────\n\nclass MetodoEnvio {\n    &lt;&lt;interface&gt;&gt;\n    +calcularCosto(p: Pedido) float\n    +estimarDias(p: Pedido) int\n}\n\nclass MetodoEnvioEstandar {\n    -api: CorreoArgentina\n    +calcularCosto(p: Pedido) float\n    +estimarDias(p: Pedido) int\n}\n\nclass MetodoEnvioExpress {\n    -api: EnvioExpressAPI\n    +calcularCosto(p: Pedido) float\n    +estimarDias(p: Pedido) int\n}\n\nclass EnvioExpress {\n    -porcentajeFijo: double\n    -cargoBase: float\n    +calcularCosto(c: float) float\n}\n\nclass MetodoRetiroSucursal {\n    -sucursal: Sucursal\n    +calcularCosto(p: Pedido) float\n    +estimarDias(p: Pedido) int\n}\n\nclass Sucursal {\n    -stock: Map~String,Registro~\n    +tieneStock(i: ItemCatalogo) boolean\n    +agregarRegistro(r: Registro) void\n    +decrementarStock(i: ItemCatalogo, n: int) void\n    +incrementarStock(i: ItemCatalogo, n: int) void\n    +tieneStockPara(p: Pedido) boolean\n}\n\nclass Direccion {\n    -calle: String\n    -altura: String\n    -ciudad: String\n    -provincia: String\n    -codigoPostal: String\n    -distanciaKm: float\n    +getDistanciaKm() float\n    +getCodigoPostal() String\n}\n\nclass CorreoArgentina {\n    &lt;&lt;interface&gt;&gt;\n    +estimarEnvio(peso: float, dir: Direccion) float\n}\n\nclass EnvioExpressAPI {\n    &lt;&lt;interface&gt;&gt;\n    +calcularCosto(precio: float) float\n}\n\nclass Registro {\n    -cantidad: int\n    -itemCatalogo: ItemCatalogo\n    +setItem() void\n    +setCantidad() void\n    +getCantidad() int\n    +getItem() ItemCatalogo    \n    +cumplePara(lp: LineaPedido) boolean\n}\n\nMetodoEnvio &lt;|.. MetodoEnvioEstandar\nMetodoEnvio &lt;|.. MetodoEnvioExpress\nMetodoEnvio &lt;|.. MetodoRetiroSucursal\nEnvioEstandar --&gt; CorreoArgentina\nEnvioExpress --&gt; EnvioExpressAPI\nRetiroSucursal --&gt; Sucursal\nSucursal --&gt; Registro\nSucursal --&gt; Direccion\nCliente --&gt; Direccion\n\n\n%% ─────────────────────────────────────────\n%% MÓDULO 4 — PAGOS (Template Method)\n%% ─────────────────────────────────────────\n\nclass ProcesadorPago {\n    &lt;&lt;abstract&gt;&gt;\n    +codigoTransaccion: String\n    +procesarPago() void\n    #validarDatos() void\n    #reservarFondos() void\n    #ejecutarTransaccion() void\n    #notificarResultado() void\n}\n\nclass PagoTarjeta {\n    -api: APITarjeta\n    #validarDatos() void\n    #reservarFondos() void\n    #ejecutarTransaccion() void\n}\n\nclass PagoTransferencia {\n    -api: APITransferencia\n    #validarDatos() void\n    #reservarFondos() void\n    #ejecutarTransaccion() void\n}\n\nclass PagoBilletera {\n    -api: APIBilletera\n    #validarDatos() void\n    #reservarFondos() void\n    #ejecutarTransaccion() void\n}\n\nclass APITarjeta {\n    &lt;&lt;interface&gt;&gt;\n    +validarTarjeta() boolean\n    +preAutorizarFondos() void\n    +ejecutarPago() String\n    +generarCupon(codigoTransaccion: String) void\n}\nclass APITransferencia {\n    &lt;&lt;interface&gt;&gt;\n    +validarCuenta() boolean\n    +ejecutarTransferencia() String\n    +generarComprobante(codigoTransaccion: String) void\n}\nclass APIBilletera {\n    &lt;&lt;interface&gt;&gt;\n    +validarSaldo() boolean\n    +bloquearSaldo() void\n    +ejecutarPago() String\n    +enviarNotificacion(codigoTransaccion: String) void\n}\n\nProcesadorPago &lt;|-- PagoTarjeta\nProcesadorPago &lt;|-- PagoTransferencia\nProcesadorPago &lt;|-- PagoBilletera\nPagoTarjeta --&gt; APITarjeta\nPagoTransferencia --&gt; APITransferencia\nPagoBilletera --&gt; APIBilletera\n\n\n%% ─────────────────────────────────────────\n%% MÓDULO 5 — NOTIFICACIONES (Observer)\n%% ─────────────────────────────────────────\n\nclass Observador {\n    &lt;&lt;interface&gt;&gt;\n    +onConfirmado(p: Pedido) void\n    +onEnviado(p: Pedido) void\n    +onEntregado(p: Pedido) void\n    +onCancelado(p: Pedido) void\n}\n\nclass NotificadorEmail {\n    -mailSender: MailSender\n    +onEntregado(p: Pedido) void \n    +onConfirmado(p: Pedido) void\n    +onEnviado(p: Pedido) void\n    -enviarPorCorreo(p: Pedido, a: String, m: String)\n}\n\nclass GeneradorFactura {\n    +onEntregado(p: Pedido) void\n    -emitirFactura(p: Pedido) void\n}\n\nclass Fidelizacion {\n    +onCancelado(p: Pedido) void\n    -emitirCupon(p: Pedido) void\n}\n\nclass MailSender {\n    &lt;&lt;interface&gt;&gt;\n    +enviarMail(dest: String, titulo: String, mensaje: String) void\n}\n\nObservador &lt;|.. NotificadorEmail\nObservador &lt;|.. GeneradorFactura\nObservador &lt;|.. Fidelizacion\nNotificadorEmail --&gt; MailSender\nPedido \&quot;1\&quot; o-- \&quot;0..*\&quot; Observador\n\n\n%% ─────────────────────────────────────────\n%% MÓDULO 6 — BÚSQUEDA (Specification + Composite)\n%% ─────────────────────────────────────────\n\nclass CriterioBusqueda {\n    &lt;&lt;interface&gt;&gt;\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass NombreContiene {\n    -texto: String\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass PrecioMaximo {\n    -maximo: float\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass PorCategoria {\n    -categoria: String\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass Disponible {\n    -sucursales: List~Sucursal~\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass And {\n    -criterios: List~CriterioBusqueda~\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass Or {\n    -criterios: List~CriterioBusqueda~\n    +cumple(i: ItemCatalogo) boolean\n}\n\nclass Not {\n    -criterio: CriterioBusqueda\n    +cumple(i: ItemCatalogo) boolean\n}\n\nCriterioBusqueda &lt;|.. NombreContiene\nCriterioBusqueda &lt;|.. PrecioMaximo\nCriterioBusqueda &lt;|.. PorCategoria\nCriterioBusqueda &lt;|.. Disponible\nCriterioBusqueda &lt;|.. And\nCriterioBusqueda &lt;|.. Or\nCriterioBusqueda &lt;|.. Not\nAnd \&quot;1\&quot; o-- \&quot;1..*\&quot; CriterioBusqueda\nOr  \&quot;1\&quot; o-- \&quot;1..*\&quot; CriterioBusqueda\nNot \&quot;1\&quot; o-- \&quot;1\&quot;    CriterioBusqueda\nDisponible --&gt; Sucursal\n\n\n%% ─────────────────────────────────────────\n%% MÓDULO 7 — REPORTES (Visitor)\n%% ─────────────────────────────────────────\n\nclass ReporteVisitor {\n    &lt;&lt;interface&gt;&gt;\n    +visitarProducto(p: Producto) void\n    +visitarPaquete(p: Paquete) void\n}\n\nclass ReporteProductosMasVendidos {\n    -fechaDesde: LocalDate\n    -fechaHasta: LocalDate\n    -entradas: List~EntradaVenta~\n    +generar(pedidos: List~Pedido~) void\n    +exportar(v: ReporteVisitor) void\n}\n\nclass EntradaVenta {\n    +item: ItemCatalogo\n    +unidadesVendidas: int\n    +precioPromedio: float\n}\n\nclass ReporteTexto {\n    +visitarProducto(p: Producto) void\n    +visitarPaquete(p: Paquete) void\n}\n\nclass ReporteCSV {\n    +visitarProducto(p: Producto) void\n    +visitarPaquete(p: Paquete) void\n}\n\nclass ReporteHTML {\n    +visitarProducto(p: Producto) void\n    +visitarPaquete(p: Paquete) void\n}\n\nReporteVisitor &lt;|.. ReporteTexto\nReporteVisitor &lt;|.. ReporteCSV\nReporteVisitor &lt;|.. ReporteHTML\nReporteProductosMasVendidos --&gt; ReporteVisitor\nReporteProductosMasVendidos \&quot;1\&quot; *-- \&quot;0..*\&quot; EntradaVenta\nEntradaVenta --&gt; ItemCatalogo&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="yKBH7q-4F5YxEr1aSjLe-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
